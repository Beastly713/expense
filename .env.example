# Root environment reference for Phase 1.
# Real app-specific env files will live inside apps later:
# - apps/api/.env
# - apps/web/.env.local

# --------------------------
# Backend (apps/api)
# --------------------------
PORT=4000
NODE_ENV=development
MONGODB_URI=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
MAIL_FROM=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
FRONTEND_URL=http://localhost:3000

# --------------------------
# Frontend (apps/web)
# --------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_NAME=Splitwise Clone