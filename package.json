{
  "name": "splitwise-clone",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.6.0",
   "scripts": {
    "dev": "concurrently \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:web": "pnpm --filter @splitwise/web dev",
    "dev:api": "pnpm --filter @splitwise/api dev",
    "build:web": "pnpm --filter @splitwise/web build",
    "build:api": "pnpm --filter @splitwise/api build",
    "lint:web": "pnpm --filter @splitwise/web lint",
    "lint:api": "pnpm --filter @splitwise/api lint",
    "typecheck:web": "pnpm --filter @splitwise/web typecheck",
    "typecheck:api": "pnpm --filter @splitwise/api typecheck",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.30.0",
    "@typescript-eslint/parser": "^8.30.0",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-import-resolver-typescript": "^4.3.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "concurrently": "^9.2.1"
  }
}